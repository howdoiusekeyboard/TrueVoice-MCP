{
  "name": "truevoice-mcp",
  "version": "1.0.0",
  "description": "A Model Context Protocol server that helps AI generate human-like text without AI slop",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "truevoice-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "writing",
    "human-like",
    "anti-slop"
  ],
  "author": "Howdoiusekeyboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/howdoiusekeyboard/truevoice-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/howdoiusekeyboard/truevoice-mcp/issues"
  },
  "homepage": "https://truevoice-mcp.vercel.app",
  "license": "MIT",
  "engines": {
    "node": ">=24.12.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.14",
    "@vercel/node": "^5.6.7",
    "typescript": "^5.9.3",
    "@biomejs/biome": "^2.4.4",
    "ultracite": "^7.2.4",
    "vercel": "^50.23.2",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "npx ultracite fix"
    ]
  }
}
